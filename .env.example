# Copy to `.env` and fill in for the production (docker-compose.prod.yml)
# deployment. `.env` is git-ignored — never commit real tokens.

# Which published image tag to run on the VPS. Use a pinned release tag for
# reproducible deploys (recommended), or `latest` to always track the newest.
#   IMAGE_TAG=v0.2.1
IMAGE_TAG=latest

# Cloudflare Tunnel token. Create the tunnel in the Cloudflare dashboard:
# Zero Trust → Networks → Tunnels → Create a tunnel (Cloudflared connector),
# then copy the token shown in the install command. Map the public hostname
# psinmr.com → service http://psinmr:80 in the tunnel's Public Hostname tab.
TUNNEL_TOKEN=
