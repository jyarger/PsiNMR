# Copy to `.env` and fill in for the production (docker-compose.prod.yml)
# deployment. `.env` is git-ignored — never commit real tokens.

# Which published image tag to run on the VPS. Use a pinned release tag for
# reproducible deploys (recommended), or `latest` to always track the newest.
#   IMAGE_TAG=v0.2.1
IMAGE_TAG=latest

# Cloudflare Tunnel token. Create the tunnel in the Cloudflare dashboard:
# Zero Trust → Networks → Tunnels → Create a tunnel (Cloudflared connector).
# The dashboard shows an install command like:
#   docker run cloudflare/cloudflared:latest tunnel --no-autoupdate run --token eyJhIjoi...
# Copy ONLY the long token string after `--token` (starts with `eyJ`, roughly
# 200 characters, no spaces, no quotes) — NOT the whole command. Do not run
# that docker command yourself: the cloudflared service in
# docker-compose.prod.yml IS the connector. Map the public hostname
# psinmr.com → service http://psinmr:80 in the tunnel's Public Hostname tab.
#
# If you change this after the stack is running, re-apply it with
#   docker compose -f docker-compose.prod.yml up -d --force-recreate cloudflared
# (a plain `restart` does NOT reload .env).
TUNNEL_TOKEN=
